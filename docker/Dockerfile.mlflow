# MLflow tracking server
FROM python:3.11-slim

RUN pip install --no-cache-dir mlflow==2.22.0 psycopg2-binary==2.9.10

WORKDIR /mlflow

EXPOSE 5000

CMD ["mlflow", "server", "--host", "0.0.0.0", "--port", "5000", "--backend-store-uri", "sqlite:///mlflow.db", "--artifacts-destination", "/mlflow/artifacts"]