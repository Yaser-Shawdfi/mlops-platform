{
  "title": "MLOps Platform - Model Monitoring",
  "tags": ["mlops", "ml"],
  "timezone": "browser",
  "schemaVersion": 30,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "title": "Predictions Served (Total)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(mlops_predictions_total)", "legendFormat": "Total", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Model AUC",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "mlops_model_auc", "legendFormat": "{{model_name}} v{{version}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.85}]}}}
    },
    {
      "title": "Model Accuracy",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "mlops_model_accuracy", "legendFormat": "{{model_name}} v{{version}}", "refId": "A"}]
    },
    {
      "title": "Drift Alerts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(mlops_drift_detected_total)", "legendFormat": "Drift Events", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}}
    },
    {
      "title": "Prediction Latency (P50/P95/P99)",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(mlops_prediction_latency_seconds_bucket[5m]))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(mlops_prediction_latency_seconds_bucket[5m]))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, rate(mlops_prediction_latency_seconds_bucket[5m]))", "legendFormat": "P99", "refId": "C"}
      ]
    },
    {
      "title": "Drift PSI by Feature",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "mlops_drift_psi", "legendFormat": "{{feature}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 0.2}]}}}
    },
    {
      "title": "Predictions Over Time",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "rate(mlops_predictions_total[5m])", "legendFormat": "{{model_name}} ({{stage}})", "refId": "A"}]
    },
    {
      "title": "Retraining Pipeline Status",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "increase(mlops_retrain_total{status=\"completed\"}[24h])", "legendFormat": "Completed (24h)", "refId": "A"},
        {"expr": "increase(mlops_retrain_total{status=\"failed\"}[24h])", "legendFormat": "Failed (24h)", "refId": "B"},
        {"expr": "increase(mlops_retrain_total{status=\"skipped\"}[24h])", "legendFormat": "Skipped (24h)", "refId": "C"}
      ]
    }
  ]
}