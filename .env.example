# MLOps Platform - Environment Variables
# Copy this file to .env and adjust values as needed.
# All variables are prefixed with MLOPS_.

# --- Platform ---
MLOPS_ENVIRONMENT=development
MLOPS_DEBUG=true

# --- MLflow ---
MLOPS_MLFLOW_TRACKING_URI=sqlite:///./data/mlflow.db
MLOPS_MLFLOW_EXPERIMENT_NAME=mlops_platform

# --- Database ---
MLOPS_DATABASE_URL=sqlite:///./data/mlops.db

# --- API ---
MLOPS_API_HOST=0.0.0.0
MLOPS_API_PORT=8000

# --- API Authentication ---
# Leave empty to disable auth (development mode).
# Set to a secure string to require X-API-Key header on protected endpoints.
MLOPS_API_KEY=

# --- Drift Detection ---
MLOPS_DRIFT_THRESHOLD_PSI=0.2
MLOPS_DRIFT_THRESHOLD_KS=0.05
MLOPS_DRIFT_CHECK_INTERVAL_MINUTES=60

# --- Retraining ---
MLOPS_RETRAIN_DRIFT_THRESHOLD=0.3
MLOPS_RETRAIN_PERFORMANCE_THRESHOLD=0.05
MLOPS_RETRAIN_MIN_SAMPLES=1000
MLOPS_RETRAIN_AUTO=false

# --- Monitoring ---
MLOPS_PROMETHEUS_PORT=9090
MLOPS_GRAFANA_PORT=3000

# --- A/B Testing ---
MLOPS_AB_MIN_SAMPLE_SIZE=1000
MLOPS_AB_SIGNIFICANCE_LEVEL=0.05